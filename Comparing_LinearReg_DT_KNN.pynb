      "source": [
        "from plotnine import *\n",
        "\n",
        "plot_data = pd.DataFrame({\n",
        "    'Model': model_names + model_names,\n",
        "    'MSE': train_errors + test_errors,\n",
        "    'Dataset': ['Training'] * len(model_names) + ['Test'] * len(model_names)\n",
        "})\n",
        "\n",
        "ggplot(plot_data, aes(x='Model', y='MSE', fill='Dataset')) + \\\n",
        "    geom_bar(stat='identity', position=position_dodge()) + \\\n",
        "    labs(title='Training and Test Errors for Models', y='Mean Squared Error') + \\\n",
        "    theme_minimal()"
